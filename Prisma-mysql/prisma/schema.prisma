generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model products {
  product_id   Int      @id @default(autoincrement())
  product_name String?  @db.VarChar(100)
  category     String?  @db.VarChar(50)
  price        Decimal? @db.Decimal(10, 2)
}
